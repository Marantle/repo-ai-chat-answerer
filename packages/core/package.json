{
  "name": "@repo-slop/core",
  "version": "0.1.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "ingest": "tsx --env-file=../../.env src/ingest/cli.ts",
    "ingest:batch": "tsx --env-file=../../.env src/ingest/batch-cli.ts",
    "eval": "tsx --env-file=../../.env src/evaluation/cli.ts"
  },
  "dependencies": {
    "@repo-slop/db": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
